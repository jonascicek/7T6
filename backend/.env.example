# Example env
PORT=4000
# Comma-separated list of allowed browser origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Required admin login credentials (email + bcrypt hash)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$replace.with.bcrypt.hash
# JWT settings
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2h
# Optional override in milliseconds (default: 7200000)
# JWT_MAX_AGE_MS=7200000
# Optional Cloudinary URL: set to the full cloudinary://... url
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
